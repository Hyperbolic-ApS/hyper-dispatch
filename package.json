  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@hono/node-server": "^2.0.1",
    "@octokit/rest": "^22.0.1",
    "dotenv": "^17.4.2",
    "hono": "^4.12.18",
    "oz-agent-sdk": "^1.3.0",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
